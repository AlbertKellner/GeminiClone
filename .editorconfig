# Indica que este é o editorconfig principal
root = true

########################################################
# Regras específicas para C# (todos os .cs)
########################################################
[*.cs]

# Se desejar, habilite warnings específicos como erros do compilador:
# (não estritamente necessário se usar WarningsAsErrors no csproj)
########################################################
# Elevar TODOS os avisos de nullable a erro
########################################################
# Possível atribuição de valor null
dotnet_diagnostic.CS8597.severity = error   # Thrown value may be null
dotnet_diagnostic.CS8598.severity = error   # Suppression operator not allowed in this context

# Conversão/atribuição/retorno/argumento de possível null
dotnet_diagnostic.CS8600.severity = error   # Converting null literal or possible null value to non-nullable type
dotnet_diagnostic.CS8601.severity = error   # Possible null reference assignment
dotnet_diagnostic.CS8602.severity = error   # Dereference of a possibly null reference
dotnet_diagnostic.CS8603.severity = error   # Possible null reference return
dotnet_diagnostic.CS8604.severity = error   # Possible null reference argument for parameter
dotnet_diagnostic.CS8605.severity = error   # Unboxing a possibly null value

# Atributos e anotações que conflitam ou não correspondem
dotnet_diagnostic.CS8607.severity = error   # A possible null value may not be used for a type marked [NotNull]/[DisallowNull]
dotnet_diagnostic.CS8608.severity = error   # Nullability of reference types in type doesn't match overridden member
dotnet_diagnostic.CS8609.severity = error   # Nullability of reference types in return type doesn't match overridden member
dotnet_diagnostic.CS8610.severity = error   # Nullability of reference types in type parameter doesn't match overridden member
dotnet_diagnostic.CS8611.severity = error   # Nullability of reference types in type parameter doesn't match partial method declaration
dotnet_diagnostic.CS8612.severity = error   # Nullability of reference types in type doesn't match implicitly implemented member
dotnet_diagnostic.CS8613.severity = error   # Nullability of reference types in return type doesn't match implicitly implemented member
dotnet_diagnostic.CS8614.severity = error   # Nullability of reference types in type of parameter doesn't match implicitly implemented member
dotnet_diagnostic.CS8615.severity = error   # Nullability of reference types in type doesn't match implemented member
dotnet_diagnostic.CS8616.severity = error   # Nullability of reference types in return type doesn't match implemented member
dotnet_diagnostic.CS8617.severity = error   # Nullability of reference types in type of parameter doesn't match implemented member

# Inicialização obrigatória
dotnet_diagnostic.CS8618.severity = error   # Non-nullable variable must contain a non-null value when exiting constructor
dotnet_diagnostic.CS8762.severity = error   # Parameter must have a non-null value when exiting
dotnet_diagnostic.CS8774.severity = error   # Member must have a non-null value when exiting
dotnet_diagnostic.CS8775.severity = error   # Member must have a non-null value when exiting
dotnet_diagnostic.CS8777.severity = error   # Parameter must have a non-null value when exiting

# Conversões e usos proibidos de nullable
dotnet_diagnostic.CS8620.severity = error   # Argument cannot be used for parameter due to nullability
dotnet_diagnostic.CS8621.severity = error   # Nullability doesn't match target delegate return
dotnet_diagnostic.CS8622.severity = error   # Nullability doesn't match target delegate parameter
dotnet_diagnostic.CS8623.severity = error   # Explicit NullableAttribute not allowed
dotnet_diagnostic.CS8624.severity = error   # Argument cannot be used as out due to nullability
dotnet_diagnostic.CS8625.severity = error   # Cannot convert null literal to non-nullable
dotnet_diagnostic.CS8628.severity = error   # Cannot use a nullable reference type in object creation
dotnet_diagnostic.CS8629.severity = error   # Nullable value type may be null

# Erros de contexto de nullable/pragma
dotnet_diagnostic.CS8631.severity = error   # Type cannot be used as type parameter; nullability mismatch
dotnet_diagnostic.CS8632.severity = error   # Nullable annotation used outside #nullable context
dotnet_diagnostic.CS8633.severity = error   # Nullability in constraints doesn't match interface method
dotnet_diagnostic.CS8634.severity = error   # Type parameter nullability mismatch with 'class' constraint
dotnet_diagnostic.CS8636.severity = error   # Invalid option for /nullable
dotnet_diagnostic.CS8637.severity = error   # Expected enable/disable/restore
dotnet_diagnostic.CS8639.severity = error   # typeof operator cannot be used on nullable reference type

# Conflito de interface explícita/implícita
dotnet_diagnostic.CS8643.severity = error   # Nullability in explicit interface specifier doesn't match
dotnet_diagnostic.CS8644.severity = error   # Base type's interface nullability mismatch
dotnet_diagnostic.CS8645.severity = error   # Member already listed in interface list with different nullability

# Exaustividade de switch
dotnet_diagnostic.CS8655.severity = error   # Switch expression not exhaustive for null inputs
dotnet_diagnostic.CS8847.severity = error   # Switch expression not exhaustive; when clause caveat

# Outros avisos diversos
dotnet_diagnostic.CS8667.severity = error   # Partial method nullability constraints mismatch
dotnet_diagnostic.CS8670.severity = error   # Initializer implicitly dereferences possibly null member
dotnet_diagnostic.CS8714.severity = error   # Type parameter nullability mismatch with 'notnull' constraint
dotnet_diagnostic.CS8763.severity = error   # [DoesNotReturn] method should not return
dotnet_diagnostic.CS8764.severity = error   # Return type nullability doesn't match overridden member
dotnet_diagnostic.CS8765.severity = error   # Parameter nullability doesn't match overridden member
dotnet_diagnostic.CS8766.severity = error   # Implicitly implemented member return nullability mismatch
dotnet_diagnostic.CS8767.severity = error   # Implicitly implemented member parameter nullability mismatch
dotnet_diagnostic.CS8768.severity = error   # Implemented member return nullability mismatch
dotnet_diagnostic.CS8769.severity = error   # Implemented member parameter nullability mismatch
dotnet_diagnostic.CS8770.severity = error   # Missing [DoesNotReturn] to match implemented/overridden member
dotnet_diagnostic.CS8824.severity = error   # Parameter must be non-null when exiting (non-nullable param)
dotnet_diagnostic.CS8825.severity = error   # Return must be non-null because parameter is non-null

dotnet_diagnostic.IDE0161.severity = error  # Eleva a violação de namespace em bloco (block‐scoped) a erro de compilação, exigindo file-scoped namespaces
dotnet_diagnostic.IDE0160.severity = none   # (Opcional) desativa warning de criação de block-scoped

# Remove diretivas `using` não utilizadas → erro de compilação
dotnet_diagnostic.IDE0005.severity = error  # Detecta e sugere remover imports que não estão sendo usados

# Diretiva `using` desnecessária → erro de compilação
dotnet_diagnostic.CS8019.severity = error  # Sinaliza imports que o compilador considera redundantes

# Categoria geral de análise de nullable
dotnet_analyzer_diagnostic.category-NullableAnalysis.severity = error

# Promove TODO diagnóstico do analisador "Nullable Analysis" a erro
dotnet_analyzer_diagnostic.category-NullableAnalysis.severity = error

# CS0168: "Variável declarada, mas nunca usada" → warning
dotnet_diagnostic.CS0168.severity = warning  # Detecta quando você faz "int x;" e nunca usa x

# CS0219: "Variável atribuída, mas seu valor nunca é usado" → warning
dotnet_diagnostic.CS0219.severity = warning  # Detecta quando você faz "var x = 5;" e nunca lê x

# IDE0059: "Remover atribuição desnecessária" → warning
dotnet_diagnostic.IDE0059.severity = warning  # Detecta quando atribui um valor a uma variável que nunca é lida

# IDE0060: "Parâmetro não utilizado" → warning
dotnet_diagnostic.IDE0060.severity = warning  # Detecta parâmetros em métodos que não são referenciados

# Warning se existir campo privado nunca usado
dotnet_diagnostic.CS0169.severity = warning  # Campo declarado mas não referenciado

# Sugestão de remoção de membro privado não lido
dotnet_diagnostic.IDE0052.severity = warning  # Remove atribuições/declarações de campos não usados

# Se quiser ainda elevar todos os analisadores do .NET a erro (opcional)
# dotnet_analyzer_diagnostic.severity = warning

########################################################
# (Opcional) Style rules de C#
# — ajuste conforme padrão do time
########################################################
csharp_style_var_elsewhere = true:suggestion  # Sugere usar 'var' em todas as declarações, mesmo quando o tipo não é imediatamente aparente
csharp_prefer_braces = false:suggestion  # Sugere não envolver blocos de controle em chaves, preferindo instruções de uma única linha sem { } quando permitido
csharp_style_namespace_declarations = file_scoped:error # Exige o estilo file-scoped namespace e trata violações como error
